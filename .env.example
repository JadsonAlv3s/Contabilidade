# ============================================================
# Variáveis de Ambiente — Danúbia Carvalho Landing Page
# ============================================================
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA versione o arquivo .env com valores reais.
# ============================================================

# E-mail de destino para recebimento dos formulários de contato
CONTACT_EMAIL=contato@danubiacarvalho.com.br

# Chave de API do Resend para envio de e-mails transacionais
# Obtenha em: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# E-mail remetente configurado no Resend (deve ser de domínio verificado)
RESEND_FROM_EMAIL=noreply@danubiacarvalho.com.br

# URL pública do site (sem barra final)
PUBLIC_SITE_URL=https://danubiacarvalho.com.br

# ID de rastreamento do Google Analytics 4 (opcional)
# Formato: G-XXXXXXXXXX
GA4_MEASUREMENT_ID=

# ID do site no Plausible Analytics (opcional, alternativa ao GA4)
PLAUSIBLE_DOMAIN=danubiacarvalho.com.br
