---
/**
 * Hero.astro — Seção principal (Hero) da landing page
 *
 * - H1: "Danúbia Carvalho"
 * - Subtítulo: "Consultoria Contábil Estratégica"
 * - Proposta de valor
 * - Indicadores de credibilidade em badges
 * - CTA primário "Fale Comigo" → #contato
 * - CTA secundário WhatsApp → nova aba
 * - Layout responsivo: centralizado mobile, esquerda desktop
 *
 * Requisitos: 2.1, 2.2, 2.3, 2.4, 2.5, 7.7, 9.3
 */

import { siteConfig } from '../config/site';

const badges = [
  '10+ anos de experiência',
  'Lucro Real',
  'Lucro Presumido',
  'Simples Nacional',
  'Entidades Sem Fins Lucrativos',
];
---

<section
  class="relative overflow-hidden bg-gradient-to-br from-brand-navy via-brand-navy to-brand-green"
  aria-labelledby="hero-heading"
>
  <!-- Logo como background fullscreen — marca d'água por trás do conteúdo -->
  <div class="absolute inset-0 flex items-center justify-center" aria-hidden="true">
    <img
      src="/images/logo-danubia.png"
      alt=""
      width="900"
      height="900"
      loading="eager"
      fetchpriority="high"
      decoding="async"
      class="w-[80vw] h-[80vw] max-w-[700px] max-h-[700px] md:max-w-[800px] md:max-h-[800px] lg:max-w-[900px] lg:max-h-[900px] object-contain opacity-[0.07] mix-blend-lighten select-none pointer-events-none"
    />
  </div>

  <!-- Overlay sutil para garantir contraste do texto -->
  <div class="absolute inset-0 bg-gradient-to-b from-brand-navy/30 via-transparent to-brand-navy/40" aria-hidden="true"></div>

  <div class="container-site relative z-10 py-20 md:py-28 lg:py-36">
    <div class="max-w-3xl mx-auto text-center">

      <!-- H1 — Nome -->
      <h1
        id="hero-heading"
        class="text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-3 drop-shadow-lg"
      >
        Danúbia Carvalho
      </h1>

      <!-- Logo acessível para SEO (visualmente oculta, lida por crawlers) -->
      <img
        src="/images/logo-danubia.png"
        alt="Logomarca Danúbia Carvalho - Consultoria Contábil Estratégica"
        width="1"
        height="1"
        class="sr-only"
        loading="eager"
      />

      <!-- Subtítulo -->
      <p class="text-xl md:text-2xl font-semibold text-green-200 mb-6 drop-shadow-md">
        Consultoria Contábil Estratégica
      </p>

      <!-- Proposta de valor -->
      <p class="text-base md:text-lg text-gray-200 leading-relaxed mb-8 max-w-2xl mx-auto drop-shadow-sm">
        Consultoria, Assessoria e Treinamento Contábil para otimizar o seu
        departamento contábil.
      </p>

      <!-- Badges de credibilidade -->
      <div
        class="flex flex-wrap gap-2 justify-center mb-10"
        aria-label="Indicadores de credibilidade"
      >
        {badges.map((badge) => (
          <span class="inline-flex items-center px-3 py-1.5 rounded-full text-sm font-medium bg-white/15 text-white border border-white/25 backdrop-blur-sm">
            {badge}
          </span>
        ))}
      </div>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center">

        <!-- CTA primário: Fale Comigo -->
        <a
          href="#contato"
          class="inline-flex items-center justify-center gap-2 px-8 py-3 min-h-[44px] rounded-lg bg-white text-brand-navy font-semibold text-base hover:bg-gray-100 transition-colors duration-200 shadow-lg hover:shadow-xl focus-visible:outline-2 focus-visible:outline-white focus-visible:outline-offset-2"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
          </svg>
          Fale Comigo
        </a>

        <!-- CTA secundário: WhatsApp -->
        <a
          href={siteConfig.social.whatsapp}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 px-8 py-3 min-h-[44px] rounded-lg bg-green-500 text-white font-semibold text-base hover:bg-green-600 transition-colors duration-200 shadow-lg hover:shadow-xl focus-visible:outline-2 focus-visible:outline-white focus-visible:outline-offset-2"
          aria-label="Entrar em contato via WhatsApp (abre em nova aba)"
          id="cta-whatsapp-hero"
          onclick="if(window.trackEvent) window.trackEvent('whatsapp_click', {location: 'hero'})"
        >
          <!-- Ícone WhatsApp -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z" />
          </svg>
          WhatsApp
        </a>
      </div>
    </div>
  </div>
</section>
