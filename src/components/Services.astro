---
/**
 * Services.astro — Seção de serviços
 *
 * - id="servicos"
 * - H2: "Nossos Serviços"
 * - 6 cards com ícone SVG, título H3 e descrição
 * - Grid responsivo: 1 col (mobile) → 2 col (tablet) → 3 col (desktop)
 * - Cards com borda, sombra sutil, hover com elevação
 *
 * Requisitos: 3.1, 3.2, 3.3, 3.4, 9.3, 9.8
 */

interface Service {
  title: string;
  description: string;
  icon: string; // SVG path data
  iconViewBox?: string;
}

const services: Service[] = [
  {
    title: 'Escrituração e Conciliação de Contas',
    description:
      'Registro sistemático e preciso de todas as transações financeiras, garantindo a integridade dos dados contábeis e a conformidade com as normas vigentes.',
    icon: 'M4 19.5A2.5 2.5 0 0 1 6.5 17H20M4 19.5A2.5 2.5 0 0 0 6.5 22H20V2H6.5A2.5 2.5 0 0 0 4 4.5v15zM8 7h8M8 11h8M8 15h5',
    iconViewBox: '0 0 24 24',
  },
  {
    title: 'Conferência de Balancetes e Encerramento de Balanços',
    description:
      'Análise criteriosa de balancetes mensais e condução do processo de encerramento contábil com rigor técnico e atenção aos detalhes.',
    icon: 'M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2M9 5a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2M9 5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2m-6 9l2 2 4-4',
    iconViewBox: '0 0 24 24',
  },
  {
    title: 'Elaboração de Demonstrações Contábeis e Obrigações Acessórias',
    description:
      'Preparação de balanços patrimoniais, DRE, DLPA e demais demonstrações, além do envio tempestivo de todas as obrigações acessórias exigidas.',
    icon: 'M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8zM14 2v6h6M16 13H8M16 17H8M10 9H8',
    iconViewBox: '0 0 24 24',
  },
  {
    title: 'Treinamentos e Capacitações no Departamento Contábil',
    description:
      'Programas de capacitação personalizados para equipes contábeis, elevando o nível técnico e a produtividade do departamento.',
    icon: 'M22 10v6M2 10l10-5 10 5-10 5z M6 12v5c3 3 9 3 12 0v-5',
    iconViewBox: '0 0 24 24',
  },
  {
    title: 'Consultorias e Análises Contábeis',
    description:
      'Assessoria estratégica com análise aprofundada das demonstrações financeiras, identificando oportunidades de melhoria e riscos contábeis.',
    icon: 'M18 20V10M12 20V4M6 20v-6',
    iconViewBox: '0 0 24 24',
  },
  {
    title: 'Elaboração de Balanços para Licitações',
    description:
      'Preparação de balanços patrimoniais e demonstrações financeiras específicas para processos licitatórios, atendendo às exigências legais e editalícias.',
    icon: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z',
    iconViewBox: '0 0 24 24',
  },
];
---

<section
  id="servicos"
  class="bg-brand-gray py-16 md:py-24"
  aria-labelledby="services-heading"
>
  <div class="container-site">

    <!-- Cabeçalho da seção -->
    <div class="text-center mb-12 md:mb-16">
      <h2
        id="services-heading"
        class="text-3xl md:text-4xl font-bold text-brand-navy mb-4"
      >
        Nossos Serviços
      </h2>
      <p class="text-gray-600 text-base md:text-lg max-w-2xl mx-auto">
        Soluções contábeis completas para otimizar o seu departamento e garantir
        conformidade com as obrigações fiscais e legais.
      </p>
    </div>

    <!-- Grid de cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
      {services.map((service) => (
        <article class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-200 flex flex-col gap-4">

          <!-- Ícone -->
          <div
            class="flex items-center justify-center w-12 h-12 rounded-lg bg-brand-navy/10 text-brand-navy flex-shrink-0"
            aria-hidden="true"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox={service.iconViewBox ?? '0 0 24 24'}
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d={service.icon} />
            </svg>
          </div>

          <!-- Conteúdo -->
          <div>
            <h3 class="text-base font-semibold text-brand-navy mb-2 leading-snug">
              {service.title}
            </h3>
            <p class="text-sm text-gray-600 leading-relaxed">
              {service.description}
            </p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
